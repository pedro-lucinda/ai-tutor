DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_tutor
TAVILY_API_KEY=tvly-...

# Auth0 (AUTH0_CLIENT_ID is frontend-only — not used by the backend)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=your-api-identifier
AUTH0_ISSUER=https://your-tenant.us.auth0.com/
AUTH0_ALGORITHMS=RS256
AUTH0_CLIENT_ID=your-spa-client-id

# Encrypt user OpenAI keys at rest (32-byte key, base64-encoded)
# Generate with: python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
APP_ENCRYPTION_KEY=

# Comma-separated frontend origins (no wildcards with credentials)
CORS_ORIGINS=http://localhost:5173

# Optional: LangSmith tracing for LangGraph / DeepAgents
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=ai-tutor
